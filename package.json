{
  "name": "structflow",
  "version": "1.4.1",
  "private": true,
  "license": "Apache-2.0",
  "homepage": "https://github.com/jessur2030/structflow",
  "repository": {
    "type": "git",
    "url": "https://github.com/jessur2030/structflow.git"
  },
  "bugs": {
    "url": "https://github.com/jessur2030/structflow/issues"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "release": "pnpm build && node -e \"const v=require('./package.json').version;const {execSync}=require('child_process');require('fs').mkdirSync('releases',{recursive:true});const out='../releases/structflow-v'+v+'.zip';execSync('rm -f '+out+' && zip -r '+out+' .',{cwd:'dist',stdio:'inherit'});console.log('Created releases/structflow-v'+v+'.zip');\"",
    "assets:store": "node scripts/gen-store-assets.cjs",
    "assets:store:annotated": "node scripts/gen-annotated-store-assets.cjs",
    "package:extension": "pnpm package:chrome",
    "package:chrome": "pnpm build && node scripts/build-browser-manifest.cjs chrome && node scripts/package-extension.cjs chrome",
    "package:edge": "pnpm build && node scripts/build-browser-manifest.cjs edge && node scripts/package-extension.cjs edge",
    "package:firefox": "pnpm build && node scripts/build-browser-manifest.cjs firefox && node scripts/package-extension.cjs firefox"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.4",
    "@codemirror/lang-cpp": "^6.0.3",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-java": "^6.0.2",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-php": "^6.0.2",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/lang-rust": "^6.0.2",
    "@codemirror/lang-sql": "^6.10.0",
    "@codemirror/lang-yaml": "^6.1.3",
    "@codemirror/language": "^6.12.4",
    "@codemirror/legacy-modes": "^6.5.3",
    "@codemirror/state": "^6.7.0",
    "@codemirror/view": "^6.43.3",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@lezer/highlight": "^1.2.3",
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-dropdown-menu": "^2.1.18",
    "@radix-ui/react-popover": "^1.1.17",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-tooltip": "^1.2.10",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "fflate": "^0.8.3",
    "highlight.js": "^11.11.1",
    "html-to-image": "^1.11.13",
    "idb": "^8.0.3",
    "lowlight": "^3.3.0",
    "lucide-react": "^1.16.0",
    "marked": "^18.0.5",
    "prettier": "^3.8.4",
    "react": "^19",
    "react-dom": "^19",
    "sql-formatter": "^15.8.1",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@types/chrome": "^0.1.43",
    "@types/hast": "^3.0.4",
    "@types/node": "^24",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.2",
    "sharp": "^0.35.1",
    "tailwindcss": "^4.2.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "5.7.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  }
}
